---
import {
  getLocaleContent,
  site,
  type Locale,
  type LocaleContent,
} from '../data/site';
import '../styles/global.css';

interface Props {
  locale: Locale;
  meta?: LocaleContent['meta'];
  canonicalPath?: string;
  includeAlternateLinks?: boolean;
}

const {
  locale,
  meta,
  canonicalPath,
  includeAlternateLinks = true,
} = Astro.props;
const content = getLocaleContent(locale);
const pageMeta = meta ?? content.meta;
const canonical = new URL(canonicalPath ?? content.path, site.url).toString();
const ogImage = new URL(site.ogImage, site.url).toString();
const alternateLocales = site.publicLocales.map(
  (publicLocale) => site.locales[publicLocale],
);
const showAlternateLinks = includeAlternateLinks && alternateLocales.length > 1;
---

<!doctype html>
<html lang={content.htmlLang} dir={content.dir}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageMeta.title}</title>
    <meta name="description" content={pageMeta.description} />
    <link rel="canonical" href={canonical} />
    {
      showAlternateLinks &&
        alternateLocales.map((localized) => (
          <link
            rel="alternate"
            hreflang={localized.htmlLang}
            href={new URL(localized.path, site.url).toString()}
          />
        ))
    }
    {
      showAlternateLinks && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={new URL(site.locales.en.path, site.url).toString()}
        />
      )
    }
    <link rel="icon" href={site.favicon} type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={pageMeta.title} />
    <meta property="og:description" content={pageMeta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageMeta.title} />
    <meta name="twitter:description" content={pageMeta.description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <slot />
  </body>
</html>
