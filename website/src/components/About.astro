---
import HeroProximityTitle from './about-motion/hero-proximity-title';
import { motionMediaQuery } from './about-motion/presets';
import BrandText from './BrandText.astro';
import type { LocaleContent } from '../data/site';

interface Props {
  content: LocaleContent;
  part?: 'intro' | 'positioning' | 'all';
}

const { content, part = 'all' } = Astro.props;
const showIntro = part === 'intro' || part === 'all';
const showPositioning = part === 'positioning' || part === 'all';
const reasonSeparator = content.htmlLang === 'zh-CN' ? '：' : ':';
const reasonJoiner = content.htmlLang === 'zh-CN' ? '' : ' ';
const locale = content.htmlLang === 'zh-CN' ? 'zh' : 'en';
---

{
  showIntro && (
    <>
      <section class="hero" aria-labelledby="page-title">
        <h1 id="page-title">
          <HeroProximityTitle
            client:media={motionMediaQuery}
            locale={locale}
            text={content.document.title}
          />
        </h1>
        <p class="hero-subtitle">{content.document.subtitle}</p>
      </section>

      <section class="section" aria-labelledby="about-heading">
        <h2 id="about-heading">{content.about.heading}</h2>
        <div class="copy-flow">
          {content.about.paragraphs.map((paragraph) => (
            <p>{paragraph}</p>
          ))}
        </div>
      </section>
    </>
  )
}

{
  showPositioning && (
    <>
      <section class="section" aria-labelledby="reasons-heading">
        <h2 id="reasons-heading">
          <BrandText text={content.reasons.heading} />
        </h2>
        <ul class="reason-list">
          {content.reasons.items.map((item) => (
            <li>
              <strong>
                {item.title}
                {reasonSeparator}
              </strong>
              {reasonJoiner}
              {item.body}
            </li>
          ))}
        </ul>
      </section>

      <section class="section" aria-labelledby="project-cta-heading">
        <h2 id="project-cta-heading">{content.closing.title}</h2>
        <div class="copy-flow">
          <p>{content.closing.body}</p>
          <div class="home-hero__actions">
            <a
              class="home-hero__button home-hero__button--primary"
              href={content.closing.href}
            >
              {content.closing.label}
            </a>
          </div>
        </div>
      </section>
    </>
  )
}
