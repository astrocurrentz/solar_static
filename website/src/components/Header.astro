---
import { getLocaleContent, site, type Locale } from '../data/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = getLocaleContent(locale);
const alternate = getLocaleContent(content.alternateLocale);
---

<header class="site-header">
  <a class="wordmark" href={content.path} aria-label={site.name}>
    <img class="site-mark" src={site.favicon} alt="" aria-hidden="true" />
  </a>
  <nav aria-label={content.navigationLabel}>
    <a
      class="language-switch"
      href={alternate.path}
      hreflang={alternate.htmlLang}
      aria-label={content.switchAriaLabel}
    >
      {content.switchLabel}
    </a>
  </nav>
</header>
