---
import BrandLoadingMark from './BrandLoadingMark.astro';
import { getLocaleContent, site, type Locale } from '../data/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = getLocaleContent(locale);
const showLanguageSwitch = site.publicLocales.length > 1;
const alternate = showLanguageSwitch
  ? getLocaleContent(content.alternateLocale)
  : undefined;
---

<header class="site-header">
  <a class="wordmark" href={site.locales.en.path} aria-label={site.name}>
    <BrandLoadingMark
      class="site-mark"
      locale={locale}
      mode="decorative"
      size="md"
    />
  </a>
  {
    showLanguageSwitch && alternate && (
      <nav aria-label={content.navigationLabel}>
        <a
          class="language-switch"
          href={alternate.path}
          hreflang={alternate.htmlLang}
          aria-label={content.switchAriaLabel}
        >
          {content.switchLabel}
        </a>
      </nav>
    )
  }
</header>
