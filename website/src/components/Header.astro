---
import BrandLoadingMark from './BrandLoadingMark.astro';
import { getLocaleContent, site, type Locale } from '../data/site';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const content = getLocaleContent(locale);
---

<header class="site-header">
  <a class="wordmark" href={site.locales.en.path} aria-label={site.name}>
    <BrandLoadingMark
      class="site-mark"
      locale={locale}
      mode="decorative"
      size="md"
    />
  </a>
  <nav class="primary-nav" aria-label={content.navigationLabel}>
    {
      content.primaryNavigation.map((item) => (
        <a class="primary-nav__link" href={item.href}>
          {item.label}
        </a>
      ))
    }
  </nav>
</header>
