---
import About from './About.astro';
import Capabilities from './Capabilities.astro';
import Footer from './Footer.astro';
import Header from './Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleContent, type Locale } from '../data/site';

interface Props {
  locale: Locale;
  canonicalPath?: string;
}

const { locale, canonicalPath } = Astro.props;
const content = getLocaleContent(locale);
---

<BaseLayout locale={locale} canonicalPath={canonicalPath}>
  <Header locale={locale} />
  <main class="page-shell">
    <About content={content} part="intro" />
    <Capabilities content={content} />
    <About content={content} part="positioning" />
  </main>
  <Footer />
</BaseLayout>
